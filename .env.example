TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DOCTOR_NAME=Dr Akanksha Prasad Cherala
# Optional but recommended if you use short names like "Dr. Akhil K. Bhat".
# Example: dr-akhil-krishnanand-bhat-general-surgeon
DOCTOR_SLUG=
LOCATION_SLUG=koramangala
APPOINTMENT_URL=https://www.superhealth.co.in/appointment/koramangala/doctors
BASE_URL=https://www.superhealth.co.in

# Slot matching rules.
# SLOT_DAYS accepts: weekends, weekdays, all, or comma-separated days like monday,wednesday,saturday
SLOT_DAYS=weekends
# Optional exact dates, comma-separated, YYYY-MM-DD.
# If SLOT_DATES is filled, these dates are checked instead of SLOT_DAYS.
SLOT_DATES=
# Optional time window for slot start time, HH:MM. Leave blank for no time limit.
SLOT_START_TIME=
SLOT_END_TIME=

CHECK_INTERVAL_SECONDS=300
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_BASE_SECONDS=1.5
USE_PLAYWRIGHT_FALLBACK=true
PLAYWRIGHT_HEADLESS=true
RUN_ONCE=false
DRY_RUN=false
LOG_LEVEL=INFO
DATA_DIR=data
LOGS_DIR=logs
NOTIFIED_SLOTS_FILE=data/notified_slots.json
